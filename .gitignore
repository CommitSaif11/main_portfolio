# --- Python / backend ---
backend/.venv/
**/__pycache__/
*.pyc
*.pyo

# --- Environment files (secrets) - never commit real values ---
.env
.env.local
.env.*.local
*.env
!*.env.example

# --- Node / frontend ---
frontend/node_modules/
frontend/dist/
frontend/build/

# --- Local databases ---
*.db
*.sqlite
*.sqlite3

# --- Dev/run logs generated while working locally ---
*.log

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Editor/IDE ---
.idea/
*.suo
*.user

# --- Claude Code session state / internal project notes ---
.claude/
context.md

# --- Local rollback safety nets - not part of the deployed app ---
data/processed/backup_sentencetransformers/
